{
  "include": ["src/**/*.ts", "tests/**/*.ts", "templates/**/template.ts"],
  "compilerOptions": {
    "target": "es2025",
    "lib": ["ES2025"],

    "module": "esnext",
    "moduleResolution": "bundler",

    "types": ["node"],

    "noEmit": true,

    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  }
}
