{
  "id": "base",
  "displayName": "Base SaaS Monorepo",
  "description": "Baseline npm-workspaces monorepo for TS-first SaaS projects.",
  "packageManagers": ["npm"],
  "templateDirectory": "templates/base",
  "reservedDirectories": ["packages"],
  "placeholderKeys": [
    "projectName",
    "packageName",
    "displayName",
    "targetDirectory",
    "webPackageName",
    "sitePackageName",
    "apiPackageName",
    "webWorkspacePath",
    "siteWorkspacePath",
    "apiWorkspacePath",
    "workspaceLayout",
    "appProjectName"
  ],
  "postGeneration": {
    "installDependencies": true,
    "initializeGit": true
  }
}
