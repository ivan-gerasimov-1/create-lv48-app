{
  "name": "create-lv48-app",
  "version": "0.3.1",
  "description": "Opinionated initializer for TS-first SaaS projects.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "create",
    "initializer",
    "scaffold",
    "typescript",
    "saas"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ivan-gerasimov-1/create-lv48-app.git"
  },
  "homepage": "https://github.com/ivan-gerasimov-1/create-lv48-app#readme",
  "bugs": {
    "url": "https://github.com/ivan-gerasimov-1/create-lv48-app/issues"
  },
  "bin": {
    "create-lv48-app": "bin/create-lv48-app.js"
  },
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "release:check": "node ./scripts/releaseCheck.mjs",
    "release:smoke": "node ./scripts/releaseSmoke.mjs",
    "release:validate-workflow": "node ./scripts/validatePublishWorkflow.mjs",
    "release:verify-pack": "node ./scripts/verifyPack.mjs",
    "test": "node --loader ./scripts/tsTestLoader.mjs --test \"tests/**/*.test.ts\"",
    "test:watch": "node --loader ./scripts/tsTestLoader.mjs --test --watch \"tests/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "24.6.1",
    "typescript": "5.9.3"
  }
}
