{
  "name": "create-lv48-app",
  "version": "0.4.0",
  "description": "Opinionated monorepo scaffold for TS-first SaaS: React/Vite, Astro, Hono",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "create",
    "initializer",
    "scaffold",
    "monorepo",
    "typescript",
    "saas",
    "react",
    "vite",
    "astro",
    "hono",
    "tailwind",
    "npm-init"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ivan-gerasimov-1/create-lv48-app.git"
  },
  "homepage": "https://github.com/ivan-gerasimov-1/create-lv48-app#readme",
  "bugs": {
    "url": "https://github.com/ivan-gerasimov-1/create-lv48-app/issues"
  },
  "bin": {
    "create-lv48-app": "bin/create-lv48-app.js"
  },
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=11"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "release:publish": "node ./scripts/releasePublish.mjs",
    "release:check": "node ./scripts/releaseCheck.mjs",
    "release:smoke": "node ./scripts/releaseSmoke.mjs",
    "release:validate-workflow": "node ./scripts/validatePublishWorkflow.mjs",
    "release:verify-pack": "node ./scripts/verifyPack.mjs",
    "test": "node --loader ./scripts/tsTestLoader.mjs --test \"tests/**/*.test.ts\" \".github/scripts/**/*.test.ts\"",
    "test:watch": "node ./scripts/watchTests.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "24.6.1",
    "typescript": "5.9.3"
  }
}
